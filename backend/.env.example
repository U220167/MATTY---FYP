# Database (PostgreSQL) - use your own credentials, never commit .env
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/attendance_db

# Server
PORT=5000
NODE_ENV=development

# Frontend URL for CORS (comma-separate if multiple)
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-secret-change-in-production
REFRESH_TOKEN_EXPIRES_IN=7d
